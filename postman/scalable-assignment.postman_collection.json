          }
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/actuator/prometheus",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "actuator",
                "prometheus"
              ]
            },
            "description": "Returns Payment Service Prometheus metrics from Spring Boot Actuator."
          }
        },
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments?limit=25",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            },
            "description": "Returns recent payments ordered by creation time descending."
          }
        },
        {
          "name": "Charge Completed Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('charge accepted', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.paymentId) pm.collectionVariables.set('paymentId', json.paymentId);",
                  "if (json.tripId) pm.collectionVariables.set('tripId', json.tripId);",
                  "if (json.reference) pm.collectionVariables.set('transactionRef', json.reference);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": \"{{tripId}}\",\n  \"amount\": {{amount}},\n  \"method\": \"{{paymentMethod}}\",\n  \"transactionRef\": \"{{transactionRef}}\"\n}"
            },
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments/charge",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "charge"
              ]
            },
            "description": "Processes a mock payment for a COMPLETED trip. Reusing transactionRef returns the existing payment."
          }
        },
        {
          "name": "Repeat Charge With Same Transaction Ref",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": \"{{tripId}}\",\n  \"amount\": {{amount}},\n  \"method\": \"{{paymentMethod}}\",\n  \"transactionRef\": \"{{transactionRef}}\"\n}"
            },
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments/charge",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "charge"
              ]
            },
            "description": "Runs the same charge again to demonstrate idempotency."
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments/{{paymentId}}",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "{{paymentId}}"
              ]
            },
            "description": "Fetches one payment by its service-owned ID."
          }
        },
        {
          "name": "Get Latest Payment By Trip Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments/trips/{{tripId}}",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "trips",
                "{{tripId}}"
              ]
            },
            "description": "Fetches the latest payment associated with a trip."
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{paymentBaseUrl}}/v1/payments/{{paymentId}}/refund",
              "host": [
                "{{paymentBaseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "{{paymentId}}",
                "refund"
              ]
            },
            "description": "Marks a payment as REFUNDED."
          }
        }
      ],
      "description": "Postman collection for the BITS ride-hailing Payment Service. Charge requests require a completed trip, and transactionRef demonstrates idempotency."
