        },
        {
          "name": "Create Rating",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('rating accepted', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('ratingId', json.id);",
                  "if (json.tripId) pm.collectionVariables.set('tripId', json.tripId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
